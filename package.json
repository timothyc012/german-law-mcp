{
  "name": "german-law-mcp",
  "version": "0.7.0",
  "description": "MCP server for German federal law — search and retrieve legislation and court decisions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "german-law-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "german-law",
    "legaltech",
    "bundesrecht",
    "neuris",
    "gesetze-im-internet",
    "eur-lex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timothyc012/german-law-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/timothyc012/german-law-mcp/issues"
  },
  "homepage": "https://github.com/timothyc012/german-law-mcp#readme",
  "author": "timothyc012",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings=0",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "verify:regression": "node scripts/legal-regression-guard.mjs",
    "verify:docs": "node scripts/check-doc-sync.mjs",
    "verify:live-law": "node scripts/legal-verify.mjs",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "verify": "npm run lint && npm run typecheck && npm run verify:regression && npm run verify:docs",
    "score": "node scripts/scorecard.mjs",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.36.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
